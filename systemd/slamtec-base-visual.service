[Unit]
Description=SLAMTEC Base Sensor Visualization Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=unitree
WorkingDirectory=/home/unitree/G1D_SLAM
ExecStart=/bin/bash scripts/base_sensor_visual_server.sh
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
